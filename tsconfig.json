{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": false,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["vite/client", "node"],
		"paths": {
			"@/*": ["./src/*"],
			"@app/*": ["./app/*"],
			"@scene/*": ["./src/scene/*"],
			"@audio/*": ["./src/audio/*"],
			"@engine/*": ["./src/engine/*"],
			"@ai/*": ["./src/ai/*"],
			"@assets/*": ["./src/assets/*"],
			"@store/*": ["./src/store/*"],
			"@platform/*": ["./src/platform/*"],
			"@shared/*": ["./src/shared/*"],
			"@world/*": ["./src/world/*"],
			"@views/*": ["./app/views/*"],
			"@components/*": ["./app/components/*"],
			"@atoms/*": ["./app/atoms/*"],
			"@hooks/*": ["./app/hooks/*"],
			"@styles/*": ["./app/styles/*"]
		}
	},
	"include": [
		"src",
		"app",
		"tests",
		"scripts",
		"vite.config.ts",
		"vitest.config.ts",
		"playwright.config.ts"
	],
	"exclude": ["node_modules", "dist", "references", ".vite"]
}
