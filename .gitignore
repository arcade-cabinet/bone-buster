# Dependencies / build artifacts
node_modules
dist
dist-android
.vite
*.log

# Capacitor native generated dirs.
# Per Capacitor's "Adding Platforms" docs: the `android/` and `ios/`
# directories ARE committed once `cap add android` / `cap add ios` has
# scaffolded them — they hold project config (Gradle build files,
# Info.plist, app icons, native plugin patches). What we DON'T commit
# is the per-build output + machine-local config inside them.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/.idea/
android/app/release/
android/captures/
ios/App/Pods/
ios/App/build/
ios/DerivedData/

# Test artifacts
test-results
playwright-report
coverage

# Raw asset sources — large, license-restricted, regenerated by
# scripts/convert-fbx.mjs into public/assets/models/. The .glb
# outputs ARE tracked; the FBX/zip sources stay local.
references/

# itch.io fetcher local-only artifacts (scripts/fetch-itch.mjs):
#   .itch-cache/   — owned-key metadata cache
#   raw-assets/    — downloaded archives + extracted contents
# Production assets live under public/assets/ after hand-promotion.
.itch-cache/
raw-assets/

# Generated WASM artifacts — scripts/prepare-web-wasm.mjs copies these
# from node_modules at postinstall + prebuild. Source of truth is the
# npm package; we don't track the byte-identical copy.
public/assets/wasm/

# IDE
.vscode
.idea
.DS_Store

# Env
.env
.env.*
!.env.example
.claude/state/
.claude/scheduled_tasks.lock
test-results/
.vitest-attachments/
src/**/__screenshots__/

# Lighthouse CI per-run report cache (uploaded to temporary-public-storage
# in CI; locally regenerated on every `pnpm lighthouse` invocation).
.lighthouseci/
