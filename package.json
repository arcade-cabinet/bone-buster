{
	"name": "objexoom",
	"private": true,
	"version": "0.4.0",
	"type": "module",
	"packageManager": "pnpm@10.2.0",
	"description": "OBJEXOOM — a polished DOOM-flavored arcade FPS. Procedural sectors, real PSX monsters, and a flashlight you absolutely need.",
	"homepage": "https://arcade-cabinet.github.io/bone-buster/",
	"repository": {
		"type": "git",
		"url": "https://github.com/objexiv/objexoom.git"
	},
	"license": "UNLICENSED",
	"scripts": {
		"postinstall": "node scripts/prepare-web-wasm.mjs",
		"prebuild": "node scripts/prepare-web-wasm.mjs",
		"dev": "vite",
		"build": "vite build && node scripts/copy-public-assets.mjs",
		"build:pages": "vite build --mode github-pages && node scripts/copy-public-assets.mjs",
		"build:native": "vite build && node scripts/copy-public-assets.mjs && cap sync",
		"assets:report": "node scripts/copy-public-assets.mjs",
		"preview": "vite preview",
		"clean": "rm -rf dist coverage test-results .vite",
		"cap": "cap",
		"cap:sync": "pnpm build && cap sync",
		"cap:sync:ios": "pnpm build && cap sync ios",
		"cap:sync:android": "pnpm build && cap sync android",
		"cap:open:ios": "cap open ios",
		"cap:open:android": "cap open android",
		"cap:run:ios": "pnpm cap:sync:ios && cap run ios",
		"cap:run:android": "pnpm cap:sync:android && cap run android",
		"check": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run --project=unit",
		"test:watch": "vitest --project=unit",
		"test:browser": "vitest run --project=browser",
		"test:browser:headed": "vitest run --project=browser --browser.headless=false",
		"test:browser:watch": "vitest --project=browser",
		"test:coverage": "vitest run --project=unit --coverage",
		"test:e2e": "playwright test",
		"test:e2e:screenshots": "playwright test tests/e2e/screenshots.spec.ts --workers=1",
		"test:e2e:archetype-screenshots": "playwright test tests/e2e/archetypeScreenshots.spec.ts --workers=1",
		"test:perf": "node scripts/obs3-perf-snapshot.mjs",
		"test:perf:mobile": "node scripts/obs3-perf-snapshot-mobile.mjs",
		"assets:fbx-to-glb": "node scripts/convert-fbx.mjs",
		"assets:bulk-fbx-to-glb": "node scripts/bulk-convert-fbx.mjs",
		"assets:audit-extracted": "node scripts/audit-extracted-assets.mjs",
		"itch:fetch": "node scripts/fetch-itch.mjs",
		"itch:fetch:dry": "node scripts/fetch-itch.mjs --dry",
		"itch:inventory": "node scripts/fetch-itch.mjs --inventory",
		"itch:refresh-keys": "node scripts/fetch-itch.mjs --refresh-keys",
		"assets:pwa-icons": "node scripts/generate-pwa-icons.mjs",
		"assets:publish-screenshots": "bash scripts/publish-screenshots.sh",
		"assets:verify-runtime": "node scripts/verify-runtime-assets.mjs",
		"assets:prepare-wasm": "node scripts/prepare-web-wasm.mjs",
		"verify": "pnpm check && pnpm lint && pnpm test && pnpm test:browser && pnpm assets:verify-runtime"
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^8.1.0",
		"@capacitor/preferences": "^8.0.1",
		"@fontsource/bungee": "^5.2.7",
		"@fontsource/bungee-inline": "^5.2.8",
		"@fontsource/bungee-shade": "^5.2.7",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/space-grotesk": "^5.2.10",
		"@fontsource/tilt-prism": "^5.2.11",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"@react-three/postprocessing": "^3.0.4",
		"framer-motion": "^12.38.0",
		"jeep-sqlite": "^2.8.0",
		"postprocessing": "^6.39.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"three": "^0.184.0",
		"three-stdlib": "^2.36.1",
		"tone": "^15.1.22",
		"yuka": "^0.7.8"
	},
	"devDependencies": {
		"7zip-min": "^3.0.1",
		"@biomejs/biome": "^2.4.10",
		"@capacitor/android": "8.3.4",
		"@capacitor/cli": "8.3.4",
		"@capacitor/core": "8.3.4",
		"@capacitor/ios": "8.3.4",
		"@playwright/test": "^1.59.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.184.0",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser": "^4.1.3",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.3",
		"fbx2gltf": "0.9.7-p1",
		"jsdom": "^29.1.1",
		"node-unrar-js": "^2.0.2",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.3"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
